# Copy to `.env` or `.env.local` and fill in values. Both are gitignored except this file.
# Vercel: Project → Settings → Environment Variables (same names, Production/Preview).

# --- Database (pick one stack) ---
# Neon / Vercel Postgres / generic Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Supabase (Postgres + Auth). App uses Anonymous sign-in + table `spend_snapshots` (see supabase/migrations).
# Prefer NEXT_PUBLIC_* for Next.js. Legacy VITE_* names are mapped in next.config.ts for the browser bundle.
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...      # optional; server-only — do not expose to the client

# --- Client-safe (exposed in the browser) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Cursor MCP (optional; see .cursor/mcp.json) ---
# Vercel + Supabase MCP use OAuth in Cursor (Settings → Tools & MCP) by default.
# For Supabase MCP with a personal access token (e.g. CI), set a token at
# https://supabase.com/dashboard/account/tokens and point mcp.json at:
#   url: https://mcp.supabase.com/mcp?project_ref=YOUR_REF
#   headers: { "Authorization": "Bearer ${env:SUPABASE_ACCESS_TOKEN}" }
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=
