# Copy to `.env` or `.env.local` and fill in values. Both are gitignored except this file.
# Vercel: Project → Settings → Environment Variables (same names, Production/Preview).

# --- Database (pick one stack) ---
# Neon / Vercel Postgres / generic Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Supabase (Postgres + optional Auth):
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  # server-only; never expose to the client

# --- Client-safe values only (exposed in the browser) ---
# VITE_* = available in client via import.meta.env.VITE_*
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
